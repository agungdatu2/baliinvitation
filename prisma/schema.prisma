datasource db {
  provider = "postgresql" // ganti ke "mysql" jika pakai MySQL/MariaDB (umum utk hosting cPanel)
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // hash bcrypt
  name      String?
  createdAt DateTime @default(now())
}

// Master daftar template yang tersedia (Lume, dst) agar admin bisa pilih di form
model Template {
  id          String       @id @default(cuid())
  key         String       @unique // "lume"
  name        String       // "Lume - Elegant Minimalist"
  thumbnail   String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  invitations Invitation[]
}

// Paket layanan yang ditawarkan ke client (dipilih saat membuat undangan)
model Package {
  id          String       @id @default(cuid())
  name        String       // "Silver", "Gold", dst
  price       Int          // harga dalam Rupiah
  description String?
  features    Json         @default("[]") // string[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  invitations Invitation[]
}

model Invitation {
  id            String   @id @default(cuid())
  slug          String   @unique // dipakai di URL: baliinvitation.com/{slug}
  status        String   @default("draft") // draft | published

  templateId    String
  template      Template @relation(fields: [templateId], references: [id])

  packageId     String?
  package       Package? @relation(fields: [packageId], references: [id])
  totalPrice    Int?     // snapshot harga paket saat undangan dibuat

  // Portal client self-service — token DI URL adalah otentikasinya (tidak ada login).
  // Digenerate via crypto.randomBytes di API (bukan cuid) karena ini token akses,
  // bukan sekadar id — harus tidak bisa ditebak sama sekali.
  portalToken          String  @unique
  portalEnabled        Boolean @default(true)
  clientCanEditEvents  Boolean @default(true)

  // Data client (internal, admin only)
  clientName    String
  clientPhone   String?
  clientNotes   String?

  // Data mempelai
  groomNickname   String
  groomFullName   String
  groomParents    String
  groomInstagram  String?
  brideNickname   String
  brideFullName   String
  brideParents    String
  brideInstagram  String?

  // Konten undangan
  coverImage    String?
  quote         String?
  greeting      String?  // paragraf "Om Swastiastu ..." / pembuka sesuai adat
  musicUrl      String?

  livestreamUrl  String? // link YouTube/Instagram Live
  livestreamNote String? // jadwal bebas, mis. "11 April 2026, 11:00-13:00 WIB"
  heroVideoUrl   String? // video background hero (mp4) — kalau kosong pakai placeholder
  dressCode      Json?   // { label: string; hex: string }[] — warna baju yang disarankan

  eventDate     DateTime // tanggal utama acara (dipakai countdown)

  galleryImages Json     @default("[]") // string[] url foto
  loveStory     Json     @default("[]") // { title: string; story: string }[]
  events        Json     @default("[]") // { name, date, timeStart, timeEnd, location, mapsUrl }[]
  bankAccounts  Json     @default("[]") // { bank, accountNumber, accountName }[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rsvps         RSVP[]
  payments      Payment[]
  guests        Guest[]
  views         InvitationView[]
  eventChangeRequests EventChangeRequest[]
}

model RSVP {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  guestName    String
  attendance   String     // hadir | tidak_hadir | belum_tahu
  guestCount   Int        @default(1)
  message      String?
  createdAt    DateTime   @default(now())

  guestId      String?    @unique
  guest        Guest?     @relation(fields: [guestId], references: [id])
}

// Tamu per-undangan untuk link personalisasi & tracking (dibuat dari Portal Client atau admin)
model Guest {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  name         String
  waNumber     String?
  category     String     @default("lainnya") // keluarga | teman | rekan | lainnya
  guestCode    String     @unique // 8 char random, non-enumerable — lihat lib/utils/tokens.ts

  status       String     @default("pending") // pending | sent | opened | responded (maju saja, tidak mundur)
  sentAt       DateTime?
  firstOpenedAt DateTime?

  rsvp         RSVP?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  views        InvitationView[]

  @@index([invitationId])
}

// Log kunjungan halaman undangan publik — dipakai untuk funnel & bedakan tracked (?g=) vs untracked (?to=/direct)
model InvitationView {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  guestId      String?
  guest        Guest?     @relation(fields: [guestId], references: [id], onDelete: SetNull)

  viaParam     String     // guest | to | direct
  createdAt    DateTime   @default(now())

  @@index([invitationId])
}

// Perubahan jadwal acara yang diajukan client dari Portal (events disimpan sbg Json array di Invitation,
// jadi diacu lewat index array, bukan FK ke tabel Event terpisah)
model EventChangeRequest {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  eventIndex   Int
  oldValues    Json
  newValues    Json
  status       String     @default("pending") // pending | approved | rejected (auto: "approved" segera jika auto-approve on)

  createdAt    DateTime   @default(now())

  @@index([invitationId])
}

// Counter window sederhana untuk throttle endpoint sensitif (mark-sent, dll) — disimpan di Postgres
// supaya konsisten lintas instance serverless (in-memory map tidak reliable di Vercel).
model RateLimitHit {
  key         String   @id // contoh: "mark-sent:{guestId}" atau "portal-auth:{ip}"
  windowStart DateTime
  count       Int      @default(1)
}

// Pembayaran/cicilan dari client untuk satu undangan (dipakai tab Income)
model Payment {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  amount       Int        // Rupiah
  paidAt       DateTime   @default(now())
  note         String?
  createdAt    DateTime   @default(now())
}
